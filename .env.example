# mock-trading-platform-gitops 환경 설정
#
# 사용법:
#   cp .env.example .env
#   vi .env                              # 실제 값을 채운다
#   ./scripts/bootstrap-values.sh        # 플레이스홀더를 치환한다
#
# Terraform output에서 자동으로 읽으려면:
#   ./scripts/bootstrap-values.sh --from-terraform ../mock-trading-platform-infra/envs/dev

# ═══════════════════════════════════════════════════════════
# A. Terraform output (mock-trading-platform-infra/envs/dev)
#    확인: terraform -chdir=../mock-trading-platform-infra/envs/dev output
# ═══════════════════════════════════════════════════════════
AWS_ACCOUNT_ID=
AWS_REGION=ap-northeast-2
EKS_CLUSTER_NAME=mock-trading-platform-dev
AWS_VPC_ID=
AWS_LBC_IRSA_ROLE_ARN=

# ═══════════════════════════════════════════════════════════
# B. External Secrets IRSA Role
#    mock-trading-platform-infra에 Terraform 리소스로 추가하거나 AWS 콘솔에서 수동 생성
#    Trust: OIDC → system:serviceaccount:external-secrets:external-secrets
#    Policy: SecretsManagerReadWrite (또는 최소 GetSecretValue)
# ═══════════════════════════════════════════════════════════
EXTERNAL_SECRETS_ROLE_ARN=

# ═══════════════════════════════════════════════════════════
# C. Helm chart 버전
#    확인: helm repo add <name> <url> && helm search repo <chart>
#    아래는 참고용 기본값. 배포 전 최신 안정 버전을 확인할 것
# ═══════════════════════════════════════════════════════════
NATS_CHART_VERSION=2.12.6
KUBE_PROMETHEUS_STACK_CHART_VERSION=72.6.2
LOKI_CHART_VERSION=6.29.0

# ═══════════════════════════════════════════════════════════
# D. AWS Secrets Manager 경로
#    생성: aws secretsmanager create-secret --name <path> --secret-string '{...}'
# ═══════════════════════════════════════════════════════════
SM_PATH_AUTH_JWT=exchange/dev/auth-jwt
SM_PATH_APP_DB=exchange/dev/app-db
SM_PATH_APP_NATS=exchange/dev/app-nats

# ═══════════════════════════════════════════════════════════
# E. Ingress 호스트명
#    커스텀 도메인이 없으면 빈 문자열로 두면 ALB가 자동 DNS를 부여한다
# ═══════════════════════════════════════════════════════════
DEV_PUBLIC_HOSTNAME=

# ═══════════════════════════════════════════════════════════
# F. 컨테이너 이미지 태그
#    CI 자동: sha-<commit>  |  수동 push: latest
# ═══════════════════════════════════════════════════════════
IMAGE_TAG=latest

# ═══════════════════════════════════════════════════════════
# G. Dev 전용 시크릿 리터럴
#    ExternalSecrets + AWS Secrets Manager 연동 전까지 임시 사용
#    운영 환경에서는 반드시 ExternalSecrets로 대체할 것
# ═══════════════════════════════════════════════════════════
DEV_JWT_SECRET=dev-jwt-secret-change-me
DEV_DB_PASSWORD=dev-db-password-change-me
DEV_DATABASE_URL=postgresql://postgres:dev-db-password-change-me@mock-trading-platform-dev-postgres-postgresql:5432/exchange?sslmode=disable
DEV_NATS_URL=nats://mock-trading-platform-dev-nats:4222
DEV_NATS_TOKEN=
