# mock-trading-platform-gitops 환경 설정
#
# 사용법:
#   cp .env.example .env
#   vi .env                              # 실제 값을 채운다
#   ./scripts/bootstrap-values.sh        # 플레이스홀더를 치환한다
#
# Terraform output에서 자동으로 읽으려면:
#   ./scripts/bootstrap-values.sh --from-terraform ../mock-trading-platform-infra/envs/dev

# ═══════════════════════════════════════════════════════════
# A. Terraform output (mock-trading-platform-infra/envs/dev)
#    확인: terraform -chdir=../mock-trading-platform-infra/envs/dev output
#
#    참고: bootstrap-values.sh --from-terraform 모드를 쓰면 이 섹션의
#    값들(AWS_ACCOUNT_ID / AWS_REGION / EKS_CLUSTER_NAME / AWS_VPC_ID /
#    AWS_LBC_IRSA_ROLE_ARN)은 .env 의 리터럴이 아니라 Terraform output 으로
#    덮어써진다. 특히 AWS_VPC_ID 는 terraform destroy/apply 사이클에서
#    값이 바뀌므로 .env 의 stale 값으로 두면 ALB controller 가 잘못된
#    VPC 에 붙는 사고가 난다 — 가능한 한 --from-terraform 을 사용하라.
# ═══════════════════════════════════════════════════════════
AWS_ACCOUNT_ID=
AWS_REGION=ap-northeast-2
EKS_CLUSTER_NAME=mock-trading-platform-dev
AWS_VPC_ID=
AWS_LBC_IRSA_ROLE_ARN=

# ═══════════════════════════════════════════════════════════
# B. External Secrets IRSA Role
#    mock-trading-platform-infra에 Terraform 리소스로 추가하거나 AWS 콘솔에서 수동 생성
#    Trust: OIDC → system:serviceaccount:external-secrets:external-secrets
#    Policy: SecretsManagerReadWrite (또는 최소 GetSecretValue)
# ═══════════════════════════════════════════════════════════
EXTERNAL_SECRETS_ROLE_ARN=

# ═══════════════════════════════════════════════════════════
# C. Helm chart 버전
#    확인: helm repo add <name> <url> && helm search repo <chart>
#    아래는 참고용 기본값. 배포 전 최신 안정 버전을 확인할 것
# ═══════════════════════════════════════════════════════════
NATS_CHART_VERSION=2.12.6
KUBE_PROMETHEUS_STACK_CHART_VERSION=72.6.2
LOKI_CHART_VERSION=6.29.0

# ═══════════════════════════════════════════════════════════
# D. AWS Secrets Manager 경로
#    생성: aws secretsmanager create-secret --name <path> --secret-string '{...}'
# ═══════════════════════════════════════════════════════════
SM_PATH_AUTH_JWT=mock-trading-platform/dev/auth-jwt
SM_PATH_APP_DB=mock-trading-platform/dev/app-db
SM_PATH_APP_NATS=mock-trading-platform/dev/app-nats

# ═══════════════════════════════════════════════════════════
# E. Ingress 호스트명
#    커스텀 도메인이 없으면 빈 문자열로 두면 ALB가 자동 DNS를 부여한다
# ═══════════════════════════════════════════════════════════
DEV_PUBLIC_HOSTNAME=

# ═══════════════════════════════════════════════════════════
# F. 컨테이너 이미지 태그
#    CI 자동: sha-<commit>  |  수동 push: latest
# ═══════════════════════════════════════════════════════════
IMAGE_TAG=latest

# ═══════════════════════════════════════════════════════════
# G. Dev 전용 시크릿 리터럴
#    ExternalSecrets + AWS Secrets Manager 연동 전까지 임시 사용
#    운영 환경에서는 반드시 ExternalSecrets로 대체할 것
# ═══════════════════════════════════════════════════════════
DEV_JWT_SECRET=dev-jwt-secret-change-me
DEV_DB_PASSWORD=dev-db-password-change-me
DEV_DATABASE_URL=postgresql://postgres:dev-db-password-change-me@mock-trading-platform-dev-postgres-postgresql:5432/mock_trading_platform?sslmode=disable
DEV_NATS_URL=nats://mock-trading-platform-dev-nats:4222
DEV_NATS_TOKEN=

# ═══════════════════════════════════════════════════════════
# H. ArgoCD repository 등록용 GitHub 자격증명
#    bootstrap-values.sh 가 argocd/repositories/*.yaml.tmpl 을
#    동일 디렉터리의 *.yaml 로 치환해 생성하고, 그 결과물을
#    `kubectl apply -n argocd -f argocd/repositories/` 로 등록한다.
#    생성된 *.yaml 은 PAT 평문을 포함하므로 .gitignore 로 추적 제외됨.
#
#    PAT scope: 권장 `repo` (private repo read 가능)
#    노출 의심 시: GitHub Settings > Developer settings > Personal access
#                  tokens 에서 즉시 revoke 후 재발급
# ═══════════════════════════════════════════════════════════
GITHUB_USER=
GITHUB_PAT=
